# Environment variables for the Lead Generation app.
# Copy this file to `.env.local` for local development, and add the same keys
# in the Vercel project settings (Project → Settings → Environment Variables)
# for production. NEVER commit your real `.env.local`.

# ───────────────────────────── REQUIRED ─────────────────────────────
# MongoDB connection string. A default is hardcoded as a fallback in
# lib/db/connect.ts but you should override it with your own cluster.
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER/lead?retryWrites=true&w=majority

# ───────────────────────────── AI ───────────────────────────────────
# Groq hosts the Llama models used by lib/ai/llamaClient.ts (cold + warm
# email generation, sales conversations). Get a key at https://console.groq.com
GROQ_API_KEY=

# Google Gemini key, used by lib/services/ai.ts + lib/analyzer/geminiAnalyzer.ts
# (website screenshots/analysis, lead scoring). Get a key at https://aistudio.google.com
GEMINI_API_KEY=

# ───────────────────────────── SCRAPING ─────────────────────────────
# SerpApi (Google Maps scraping) — https://serpapi.com
SERP_API_KEY=

# ScrapingDog (alternative scraper) — https://www.scrapingdog.com
SCRAPINGDOG_API_KEY=

# ───────────────────────────── EMAIL (SMTP) ─────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Ahmed Hassan
SMTP_FROM_EMAIL=

# ───────────────────────────── GOOGLE SHEETS EXPORT ─────────────────
# Service-account JSON key for the Google Sheets API. Used by
# lib/services/googlesheet.ts to export leads daily. Optional — if missing,
# the daily export cron marks leads as exported locally instead of failing.
GOOGLE_CLIENT_EMAIL=
# Paste the private key with \n escapes, OR base64-encode the whole key and
# use GOOGLE_PRIVATE_KEY_BASE64 (safer for Vercel's single-line fields).
GOOGLE_PRIVATE_KEY=
GOOGLE_PRIVATE_KEY_BASE64=
GOOGLE_SHEET_ID=

# ───────────────────────────── CRON / APP ───────────────────────────
# Secret used to protect Vercel Cron endpoints (app/api/cron/*). Vercel sends
# this as the `Authorization: Bearer <CRON_SECRET>` header. Optional but
# recommended.
CRON_SECRET=

# Public site URL (used for absolute links in emails, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CRON_SECRET=
