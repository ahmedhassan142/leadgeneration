{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/outreach/process",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/process-queue",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/process-followups",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/daily-scrape",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/daily-export",
      "schedule": "55 23 * * *"
    }
  ]
}
